{
    "name": "dskripchenko/laravel-admin-starter",
    "description": "Готовые системные Resource'ы (Users, Roles, AuditLog, Settings, Translations, ContentBlocks) для dskripchenko/laravel-admin.",
    "type": "library",
    "keywords": [
        "laravel",
        "admin",
        "starter",
        "users",
        "roles",
        "audit",
        "settings",
        "translations",
        "dskripchenko"
    ],
    "homepage": "https://github.com/dskripchenko/laravel-admin-starter",
    "license": "MIT",
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/dskripchenko/laravel-admin-starter/issues",
        "source": "https://github.com/dskripchenko/laravel-admin-starter"
    },
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminStarter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminStarter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminStarter\\AdminStarterServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
